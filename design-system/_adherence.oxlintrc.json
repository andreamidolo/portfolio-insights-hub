{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "charts/**",
              "components/cards/**",
              "components/core/**",
              "components/layout/**",
              "components/navigation/**",
              "exports/brochure-handoff/template/**",
              "exports/lfg-handoff/01-institutional-brochure/LFA/brochure/**",
              "exports/lfg-handoff/01-institutional-brochure/LFG-ZEST/brochure-en/**",
              "exports/lfg-handoff/01-institutional-brochure/LFG-ZEST/brochure-it/**",
              "exports/lfg-handoff/01-institutional-brochure/charts/**",
              "exports/lfg-handoff/02-factsheet-editor/factsheet/**",
              "exports/lfg-handoff/02-factsheet-editor/zest-napr-template/**",
              "exports/lfg-handoff/03-one-pager/**",
              "list-template/**",
              "proposals/investment-process/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant Garamond|Mulish))/i]",
        "message": "Font not provided by the design system. Available: Cormorant Garamond, Mulish."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|href|iconRight|disabled|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, href, iconRight, disabled, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|outline|navy|link)$/]",
        "message": "<Button> variant must be one of 'primary' | 'outline' | 'navy' | 'link'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|as|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, tone, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:rose|navy|muted|white)$/]",
        "message": "<Eyebrow> tone must be one of 'rose' | 'navy' | 'muted' | 'white'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|children|align|boxed|key|ref|className|style|children)$/]",
        "message": "<FeatureCard> doesn't accept that prop. Declared props: icon, title, children, align, boxed."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<FeatureCard> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MandateTabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|value|defaultValue|onChange|key|ref|className|style|children)$/]",
        "message": "<MandateTabs> doesn't accept that prop. Declared props: items, value, defaultValue, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:logoSrc|leftLinks|rightLinks|cta|active|onNavigate|onCta|key|ref|className|style|children)$/]",
        "message": "<NavBar> doesn't accept that prop. Declared props: logoSrc, leftLinks, rightLinks, cta, active, onNavigate, onCta."
      },
      {
        "selector": "JSXOpeningElement[name.name='RoseSection'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|watermark|padding|key|ref|className|style|children)$/]",
        "message": "<RoseSection> doesn't accept that prop. Declared props: children, watermark, padding."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|lead|align|tone|italic|key|ref|className|style|children)$/]",
        "message": "<SectionHeading> doesn't accept that prop. Declared props: eyebrow, title, lead, align, tone, italic."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<SectionHeading> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:navy|white)$/]",
        "message": "<SectionHeading> tone must be one of 'navy' | 'white'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|suffix|tone|align|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: value, label, suffix, tone, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:navy|rose|white)$/]",
        "message": "<StatCard> tone must be one of 'navy' | 'rose' | 'white'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<StatCard> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|navy|rose|outline)$/]",
        "message": "<Tag> tone must be one of 'neutral' | 'navy' | 'rose' | 'outline'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
